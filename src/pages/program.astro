---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProgramCard from '../components/ProgramCard.astro';
import { getPrograms } from '../lib/supabase/queries/marketing';
import { programs as fallbackPrograms, donasiUrl } from '../data/programs';
import { formatRupiahCompact } from '../lib/format';

// SSR: list all published CMS campaigns; fall back to the static programs.ts
// when the DB is empty / unreachable.
const dbPrograms = await getPrograms(Astro.locals.supabase);
const programs = dbPrograms.length > 0
  ? dbPrograms
  : fallbackPrograms.map((p) => ({ ...p, donasi_url: donasiUrl(p.slug) }));
const categories = ['Kafarat', 'Fidyah', 'Kemanusiaan'] as const;

// Aggregate impact stats for the header strip (DB rows only — fallback rows
// carry no live figures). Social proof shown above the grid.
const totalRaised = dbPrograms.reduce((s, p) => s + (p.raised_amount ?? 0), 0);
const totalDonatur = dbPrograms.reduce((s, p) => s + (p.donatur_count ?? 0), 0);
const hasImpact = totalRaised > 0 || totalDonatur > 0;
const impactStats = [
  { value: formatRupiahCompact(totalRaised), label: 'Terkumpul' },
  { value: totalDonatur.toLocaleString('id-ID'), label: 'Donatur' },
  { value: String(programs.length), label: 'Program Aktif' },
];
---

<Base title="Program Donasi — Yayasan Alhidayah" description="Daftar lengkap program donasi Yayasan Alhidayah: Kafarat, Fidyah, dan program kemanusiaan. Titipkan amanah Anda hari ini.">
  <Header base="/" />

  <section class="section-pad program-page">
    <div class="container">
      <div class="program-page-head" data-reveal>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="breadcrumb__home">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/>
            </svg>
            <span>Beranda</span>
          </a>
          <svg class="breadcrumb__sep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg>
          <span aria-current="page">Program Donasi</span>
        </nav>
        <div class="eyebrow"><span class="section-num">Salurkan Amanah Anda</span></div>
        <h1 class="display">
          Semua program yang<br/>bisa Anda <em>titipkan</em>.
        </h1>
        <p class="lede program-page-lede">
          Pilih kategori untuk menyaring program, atau lihat semua sekaligus. Setiap program adalah jembatan antara niat baik Anda dan mereka yang sedang menunggu bantuan.
        </p>

        {hasImpact && (
          <dl class="impact-strip" aria-label="Ringkasan dampak donasi">
            {impactStats.map((s) => (
              <div class="impact-stat">
                <dt class="impact-stat__value">{s.value}</dt>
                <dd class="impact-stat__label">{s.label}</dd>
              </div>
            ))}
          </dl>
        )}

        <div class="category-filter" role="tablist" aria-label="Filter kategori program">
          <button class="filter-chip is-active" role="tab" aria-selected="true" data-filter="all">
            Semua
            <span class="count">{programs.length}</span>
          </button>
          {categories.map((c) => (
            <button class="filter-chip" role="tab" aria-selected="false" data-filter={c}>
              {c}
              <span class="count">{programs.filter((p) => p.category === c).length}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="programs-grid" id="programs-grid">
        {programs.map((p) => <ProgramCard p={p} category={p.category} />)}
      </div>

      <div class="program-empty" id="programs-empty" hidden>
        <p>Tidak ada program untuk kategori ini.</p>
      </div>
    </div>
  </section>

  <Footer base="/" />

  <script is:inline>
    (function() {
      var chips = document.querySelectorAll('.filter-chip');
      var cards = document.querySelectorAll('#programs-grid .program-card');
      var empty = document.getElementById('programs-empty');
      if (!chips.length || !cards.length) return;
      function apply(filter) {
        var visible = 0;
        cards.forEach(function(c) {
          var match = filter === 'all' || c.getAttribute('data-category') === filter;
          c.hidden = !match;
          if (match) visible++;
        });
        if (empty) empty.hidden = visible > 0;
      }
      chips.forEach(function(chip) {
        chip.addEventListener('click', function() {
          chips.forEach(function(c) { c.classList.remove('is-active'); c.setAttribute('aria-selected', 'false'); });
          chip.classList.add('is-active');
          chip.setAttribute('aria-selected', 'true');
          apply(chip.getAttribute('data-filter'));
        });
      });
    })();
  </script>
</Base>