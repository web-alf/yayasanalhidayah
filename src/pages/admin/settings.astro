---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import SettingsForm from '@/components/admin/settings/SettingsForm';
import { getSettings } from '@/lib/supabase/queries/marketing';

const settings = await getSettings(Astro.locals.supabase);
---
<AdminLayout title="Pengaturan">
  <SettingsForm client:load initial={{
    contact: settings.contact as any ?? {},
    social: settings.social as any ?? {},
    about: settings.about as any ?? {},
    donorcta: settings.donorcta as any ?? {},
    footer: settings.footer as any ?? {},
  }} />
</AdminLayout>
