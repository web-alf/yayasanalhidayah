---
const heroImages = [
  { src: '/hero-1.webp', fallback: '/hero-1.jpg', alt: 'Kegiatan Yayasan Alhidayah 1' },
  { src: '/hero-2.webp', fallback: '/hero-2.jpg', alt: 'Kegiatan Yayasan Alhidayah 2' },
  { src: '/hero-3.webp', fallback: '/hero-3.jpg', alt: 'Kegiatan Yayasan Alhidayah 3' },
  { src: '/hero-4.webp', fallback: '/hero-4.jpg', alt: 'Kegiatan Yayasan Alhidayah 4' },
];
---

<section class="hero" id="top">
  <div class="container">
    <div class="hero-C on-deep">
      <div class="hero-bg">
        {heroImages.map((img, i) => (
          <picture>
            <source srcset={img.src} type="image/webp" />
            <img
              class={`hero-slide ${i === 0 ? 'active' : ''}`}
              src={img.fallback}
              alt={img.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              decoding={i === 0 ? 'sync' : 'async'}
              width="1000"
              height="449"
              data-hero-slide={i}
            />
          </picture>
        ))}
      </div>
      <div class="hero-overlay">
        <div class="hero-overlay-content">
          <div>
            <div class="eyebrow hero-fade" style="--d:0">Yayasan Alhidayah · Bandung Barat</div>
            <h1 class="display hero-h1 hero-fade" style="margin-top: 16px; --d:1">
              Belajar tidak <em>selalu</em> nyaman, tapi selalu <em>bermakna.</em>
            </h1>
          </div>
          <div class="hero-fade" style="--d:2">
            <p class="lede hero-lede">
              Setiap sudut ruangan ini menyimpan proses: <strong style="color: var(--ink-on-deep);">mencoba, gagal, memahami, lalu tumbuh</strong> — perjalanan amanah yang kami jaga.
            </p>
            <div class="ctas" style="margin-top: 24px;">
              <a class="btn btn-primary" href="#program">
                Lihat Program Donasi <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
              </a>
              <a class="btn btn-ghost" href="#tentang">
                Tentang Yayasan
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item hero-fade" style="--d:3">
        <div class="num" data-counter="2025"></div>
        <div class="lbl">Berbadan Hukum</div>
      </div>
      <div class="hero-meta-item hero-fade" style="--d:4">
        <div class="num" data-counter="100" data-suffix="%"></div>
        <div class="lbl">Tepat Sasaran</div>
      </div>
      <div class="hero-meta-item hero-fade" style="--d:5">
        <div class="num" data-counter="3"></div>
        <div class="lbl">Program Aktif</div>
      </div>
    </div>
  </div>
</section>
