---

<header class="nav" id="main-nav">
  <div class="container">
    <div class="nav-inner">
      <a class="brand" href="#top">
        <picture>
          <source srcset="/logo-clear.webp" type="image/webp" />
          <img class="logo-img" src="/logo-clear.png" alt="Logo Yayasan Alhidayah" width="36" height="36" />
        </picture>
        <span class="brand-name">
          <span class="b1">Alhidayah</span>
          <span class="b2">yayasanalhidayah.com</span>
        </span>
      </a>
      <div class="nav-actions">
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
          <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a class="btn btn-primary nav-donate" href="#program" style="padding: 12px 22px; font-size: 14px;">
          Donasi <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
          <span class="hamburger">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
          </span>
        </button>
      </div>
    </div>
  </div>
  <nav class="nav-links" id="nav-links">
    <a href="#tentang">Tentang</a>
    <a href="#mengapa">Mengapa Kami</a>
    <a href="#program">Program</a>
    <a href="#testimoni">Testimoni</a>
    <a href="#kontak">Kontak</a>
  </nav>
  <div class="nav-backdrop" id="nav-backdrop"></div>
</header>

<script is:inline>
  (function() {
    var nav = document.getElementById('main-nav'), tgl = document.getElementById('nav-toggle'),
        lnk = document.getElementById('nav-links'), bd = document.getElementById('nav-backdrop');
    window.addEventListener('scroll', function() { nav.classList.toggle('scrolled', window.scrollY > 40); }, { passive: true });
    if (window.scrollY > 40) nav.classList.add('scrolled');
    function close() { lnk.classList.remove('open'); tgl.classList.remove('open'); bd.classList.remove('open'); }
    if (tgl && lnk) {
      tgl.addEventListener('click', function() { var o = lnk.classList.toggle('open'); tgl.classList.toggle('open', o); bd.classList.toggle('open', o); });
      lnk.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', close); });
      bd.addEventListener('click', close);
    }
    var tb = document.getElementById('theme-toggle'), sun = document.getElementById('icon-sun'), moon = document.getElementById('icon-moon');
    function upd() { var dk = document.documentElement.getAttribute('data-theme') === 'dark'; sun.style.display = dk ? 'none' : 'block'; moon.style.display = dk ? 'block' : 'none'; }
    upd();
    tb.addEventListener('click', function() {
      var dk = document.documentElement.getAttribute('data-theme') === 'dark';
      dk ? (document.documentElement.removeAttribute('data-theme'), localStorage.removeItem('theme')) : (document.documentElement.setAttribute('data-theme', 'dark'), localStorage.setItem('theme', 'dark'));
      upd();
    });
  })();
</script>
