---
import { getSettings } from '../lib/supabase/queries/marketing';

const settings = await getSettings(Astro.locals.supabase);
const about = (settings.about ?? {}) as Record<string, string>;

const heading = about.heading || 'Lembaga sosial &\nkeagamaan dari\nBandung Barat.';
const pillars = (about.pillars || 'Amanah, Tepat Sasaran, Sesuai Syariat').split(',').map(s => s.trim()).filter(Boolean);
const paragraphs = (about.body || `Yayasan Alhidayah berpusat di Kabupaten Bandung Barat. Kami bergerak dalam penyaluran <strong>kafarat, fidyah,</strong> serta bantuan sosial kepada fakir miskin, anak yatim, dan penggiat dakwah. Setiap amanah yang dititipkan kami salurkan langsung kepada penerima yang benar-benar membutuhkan.

Kami sering bertemu mereka yang menunggu bantuan datang bukan untuk kenyang, tapi untuk bertahan. Dari situlah amanah ini kami jaga — agar setiap kafarat dan wakaf benar-benar sampai. Karena bagi mereka, bantuan ini bukan soal sedekah; tapi soal hari ini bisa bertahan atau tidak.

Di setiap bantuan yang sampai, ada amanah dari orang-orang baik yang memilih tidak menunda kebaikan. Dan di titik itulah, kami percaya: <strong>menunda kafarat atau wakaf bukan hanya menunda pahala, tapi menunda kehidupan seseorang.</strong>`).split('\n\n').filter(Boolean);
---

<section class="about section-pad" id="tentang">
  <div class="container">
    <div class="about-grid">
      <div data-reveal>
        <div class="eyebrow"><span class="section-num">01 / Tentang Kami</span></div>
        <h2 class="display about-h2" set:html={heading.replace(/\n/g, '<br/>')} />
        <div class="about-pillars">
          {pillars.map((p) => <span class="about-pillar">{p}</span>)}
        </div>
      </div>
      <div class="about-body" data-reveal>
        {paragraphs.map((p) => <p set:html={p} />)}
      </div>
    </div>
  </div>
</section>
