---
import { formatRupiah, formatRupiahCompact } from '../lib/format';

// One program card. Renders the editorial body (image/tag/title/desc/CTA) plus,
// when the row carries live donation stats from the WP sync (raised_amount /
// donatur_count / target_amount / progress_pct), a compact progress block. Rows
// without stats (e.g. static fallback, or not yet synced) render without it.
export interface ProgramLike {
  title: string;
  category?: string;
  tag: string;
  slug: string;
  image: string;
  alt: string;
  description: string;
  donasi_url: string;
  raised_amount?: number | null;
  donatur_count?: number | null;
  target_amount?: number | null;
  days_left?: number | null;
  progress_pct?: number | null;
}

interface Props {
  p: ProgramLike;
  category?: string; // optional data attr for the filter on /program
}
const { p, category } = Astro.props;

const raised = p.raised_amount ?? null;
const donatur = p.donatur_count ?? null;
const target = p.target_amount ?? null;
const pct = p.progress_pct ?? null;
const hasStats = (raised != null && raised > 0) || (donatur != null && donatur > 0);
const hasBar = hasStats && target != null && target > 0 && pct != null;
---

<article class="program-card" data-reveal data-category={category}>
  <div class="program-img skeleton">
    <img src={p.image} alt={p.alt} loading="lazy" decoding="async" width="800" height="600" />
    <span class="program-tag">{p.tag}</span>
  </div>
  <div class="program-body">
    <h3>{p.title}</h3>
    <p>{p.description}</p>

    {hasStats && (
      <div class="program-progress">
        {hasBar && (
          <div class="program-progress-bar" role="progressbar"
               aria-valuenow={Math.round(pct!)} aria-valuemin="0" aria-valuemax="100">
            <span style={`width: ${Math.min(100, Math.max(0, pct!))}%`} />
          </div>
        )}
        <div class="program-progress-meta">
          <span class="raised"><strong>{formatRupiahCompact(raised)}</strong> terkumpul</span>
          <span class="donatur">{donatur ?? 0} donatur</span>
        </div>
      </div>
    )}

    <a href={p.donasi_url} class="program-cta" target="_blank" rel="noopener noreferrer">
      Titipkan amanah <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
    </a>
  </div>
</article>
