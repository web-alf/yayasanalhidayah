---
import { getSettings } from '../lib/supabase/queries/marketing';

const settings = await getSettings(Astro.locals.supabase);
const contact = (settings.contact ?? {}) as Record<string, string>;
const whatsapp = contact.whatsapp || '6285177007772';
const waLink = `https://wa.me/${whatsapp}?text=Assalamu'alaikum%2C%20saya%20ingin%20bertanya%20tentang%20Yayasan%20Alhidayah`;
---

<a class="fab-wa" href={waLink} aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
  <svg width="28" height="28" viewBox="0 0 32 32" fill="#fff">
