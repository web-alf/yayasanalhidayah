---
import type { Program } from '../lib/supabase/queries/marketing';
import ProgramCard from './ProgramCard.astro';

interface Props {
  programs?: Program[];
}
// Falls back to the static programs.ts only when no CMS data is passed (e.g. an
// empty DB before seed). When index.astro passes live rows, those win.
import { latestPrograms as fallbackPrograms, donasiUrl } from '../data/programs';
const { programs } = Astro.props;
const items = (programs && programs.length > 0) ? programs : fallbackPrograms.map((p) => ({ ...p, donasi_url: donasiUrl(p.slug) }));
---

<section class="section-pad" id="program">
  <div class="container">
    <div class="programs-head">
      <div data-reveal>
        <div class="eyebrow"><span class="section-num">03 / Program Donasi</span></div>
        <h2 class="display">
          Pilih amal terbaik<br/>yang ingin Anda <em>titipkan</em>.
        </h2>
      </div>
      <p class="lede" data-reveal>
        Setiap program di bawah ini bukan sekadar pilihan amal, tapi jawaban bagi mereka yang sedang menunggu bantuan hari ini.
      </p>
    </div>
    <div class="programs-grid">
      {items.map((p) => <ProgramCard p={p} />)}
    </div>
    <div class="programs-foot" data-reveal>
      <a href="/program" class="btn btn-ghost">
        Lihat Semua Program
        <span class="arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>
    </div>
  </div>
</section>
