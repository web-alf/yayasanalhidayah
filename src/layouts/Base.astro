---
import '../styles/global.css';
import { getSeoSettings, buildTitle } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  rawTitle?: boolean; // skip the global separator (article pages pass a fully-formed title)
}

const { title, description, noindex = false, canonical, ogImage, rawTitle = false } = Astro.props;
// Pull Rank-Math-style global SEO settings from the CMS (gracefully returns
// defaults when Supabase is unreachable, e.g. build-time prerender of /404).
const seo = await getSeoSettings(Astro.locals?.supabase ?? null);
const resolvedTitle = rawTitle ? title : buildTitle(title, seo);
const resolvedDescription = description || seo.homepage_description || 'Yayasan Alhidayah — Lembaga sosial & keagamaan dari Bandung Barat. Wakaf mushaf Al-Quran, kafarat, dan bantuan sosial untuk fakir miskin, anak yatim, dan penggiat dakwah.';
const canonicalUrl = canonical || new URL(Astro.url.pathname, 'https://yayasanalhidayah.com').href;
const ogImageUrl = ogImage || seo.default_og_image || 'https://yayasanalhidayah.com/hero/hero-1.webp';
const ga4Id = seo.ga4_id?.trim() || '';
const gsc = seo.gsc_verification?.trim() || '';
const bing = seo.bing_verification?.trim() || '';
const robotsContent = (noindex || !seo.robots_index) ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "NGO"],
      "@id": "https://yayasanalhidayah.com/#organization",
      "name": "Yayasan Alhidayah",
      "alternateName": "Alhidayah Foundation",
      "url": "https://yayasanalhidayah.com",
      "logo": "https://yayasanalhidayah.com/logo-clear.png",
      "description": "Lembaga sosial dan keagamaan berbadan hukum dari Bandung Barat yang bergerak di bidang wakaf mushaf Al-Quran, kafarat, dan bantuan sosial.",
      "foundingDate": "2025",
      "legalName": "Yayasan Alhidayah",
      "taxID": "31.714.301.4-421.000",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Kampung Pamokokolan RT 03/01, Desa Bunijaya",
        "addressLocality": "Gununghalu",
        "addressRegion": "Kabupaten Bandung Barat",
        "addressCountry": "ID"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -6.89,
        "longitude": 107.34
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+62-851-7700-7772",
        "contactType": "customer service",
        "availableLanguage": "Indonesian"
      },
      "sameAs": [
        "https://www.instagram.com/@aksibaikalhidayah",
        "https://www.facebook.com/Yas%20Alhidayah"
      ],
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Kabupaten Bandung Barat, Jawa Barat, Indonesia"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://yayasanalhidayah.com/#website",
      "url": "https://yayasanalhidayah.com",
      "name": "Yayasan Alhidayah",
      "publisher": { "@id": "https://yayasanalhidayah.com/#organization" },
      "inLanguage": "id-ID"
    },
    {
      "@type": "WebPage",
      "@id": canonicalUrl,
      "url": canonicalUrl,
      "name": title,
      "description": description,
      "isPartOf": { "@id": "https://yayasanalhidayah.com/#website" },
      "about": { "@id": "https://yayasanalhidayah.com/#organization" },
      "inLanguage": "id-ID"
    }
  ]
};
---

<!doctype html>
<html lang="id" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#FFFFF0" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0E1525" media="(prefers-color-scheme: dark)" />
  <link rel="preload" as="image" href="/hero/hero-1.webp" type="image/webp" fetchpriority="high" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://wa.me" />
  <title>{resolvedTitle}</title>
  <meta name="description" content={resolvedDescription} />

  {/* Search-engine verification (Rank Math SEO settings). */}
  {gsc && <meta name="google-site-verification" content={gsc} />}
  {bing && <meta name="msvalidate.01" content={bing} />}

  <!-- SEO -->
  <meta name="robots" content={robotsContent} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="id" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <!-- GEO targeting -->
  <meta name="geo.region" content="ID-JB" />
  <meta name="geo.placename" content="Kabupaten Bandung Barat" />
  <meta name="geo.position" content="-6.89;107.34" />
  <meta name="ICBM" content="-6.89, 107.34" />

  <!-- Open Graph -->
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Yayasan Alhidayah" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1000" />
  <meta property="og:image:height" content="449" />
  <meta property="og:image:alt" content="Kegiatan Yayasan Alhidayah — Wakaf & Kafarat" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedTitle} />
  <meta name="twitter:description" content={resolvedDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  {/* Google Analytics 4 (Rank Math SEO settings) — only when a Measurement ID is set. */}
  {ga4Id && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>}
  {ga4Id && (
    <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
  )}

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/logo.webp" type="image/webp" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Fonts — single combined request, async loaded -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=optional"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=optional" /></noscript>

  <!-- Theme init (prevent flash) -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    })();
  </script>
</head>
<body>
  <slot />

  <script is:inline>
    (function() {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('[data-reveal],[data-reveal-img]').forEach(function(el) { io.observe(el); });
    })();
  </script>
  <script is:inline>
    (window.requestIdleCallback || setTimeout)(function() {
      document.querySelectorAll('img[loading="lazy"]').forEach(function(img) {
        function r() { img.classList.add('loaded'); var p = img.closest('.skeleton'); if (p) p.classList.remove('skeleton'); }
        if (img.complete) r(); else img.addEventListener('load', r);
      });
      var hs = document.querySelectorAll('.hero-slide');
      if (hs.length > 1) { var c = 0; setInterval(function() { hs[c].classList.remove('active'); c = (c + 1) % hs.length; hs[c].classList.add('active'); }, 3000); }
      var cio = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting) return;
          var el = e.target, t = +el.getAttribute('data-counter'), s = el.getAttribute('data-suffix') || '', d = t > 100 ? 2000 : 1200, st = 0;
          el.textContent = '0' + s;
          (function step(ts) { if (!st) st = ts; var p = Math.min((ts - st) / d, 1), c1 = 1.70158, v = Math.min(Math.round((1 + (c1+1) * Math.pow(p-1,3) + c1 * Math.pow(p-1,2)) * t), t); el.textContent = v + s; p < 1 ? requestAnimationFrame(step) : (el.textContent = t + s, el.classList.add('counter-done')); })(performance.now());
          cio.unobserve(el);
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-counter]').forEach(function(el) { cio.observe(el); });
    });
  </script>
</body>
</html>
